% vocabulary-extra.p0 — synonyms, antonyms and defining-phrase vocabulary (gen344).
% synonym/2 answers "another word for X"; opposite/2 answers "the opposite of X"
% (both directions stored, matching the existing convention); word_for(Phrase,
% Word) answers "what word describes ...". One clause per line.

% ============================================================
% SYNONYMS — synonym(A, B), both directions
% ============================================================
synonym(begin, start).
synonym(start, begin).
synonym(end, finish).
synonym(finish, end).
synonym(quick, fast).
synonym(fast, quick).
synonym(smart, clever).
synonym(clever, smart).
synonym(sad, unhappy).
synonym(unhappy, sad).
synonym(glad, pleased).
synonym(pleased, glad).
synonym(tired, weary).
synonym(weary, tired).
synonym(rich, wealthy).
synonym(wealthy, rich).
synonym(strange, odd).
synonym(odd, strange).
synonym(tiny, minuscule).
synonym(minuscule, tiny).
synonym(quiet, silent).
synonym(silent, quiet).
synonym(strong, powerful).
synonym(powerful, strong).
synonym(difficult, hard).
synonym(hard, difficult).
synonym(easy, simple).
synonym(simple, easy).
synonym(important, significant).
synonym(significant, important).
synonym(beautiful, gorgeous).
synonym(gorgeous, beautiful).
synonym(scared, afraid).
synonym(afraid, scared).
synonym(funny, amusing).
synonym(amusing, funny).
synonym(smart, intelligent).
synonym(intelligent, smart).
synonym(buy, purchase).
synonym(purchase, buy).
synonym(help, assist).
synonym(assist, help).
synonym(show, display).
synonym(display, show).
synonym(make, create).
synonym(create, make).
synonym(answer, reply).
synonym(reply, answer).
synonym(idea, concept).
synonym(concept, idea).
synonym(job, occupation).
synonym(occupation, job).
synonym(happy, joyful).
synonym(joyful, happy).

