sound_of(lion, roar).
sound_of(wolf, howl).
sound_of(snake, hiss).
sound_of(bee, buzz).
sound_of(frog, croak).
sound_of(owl, hoot).
sound_of(horse, neigh).
sound_of(donkey, bray).
sound_of(sheep, bleat).
eats(panda, bamboo).
eats(koala, eucalyptus).
eats(giraffe, leaves).
eats(whale, krill).
eats(caterpillar, leaves).