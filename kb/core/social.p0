progenitor(tom, bob).   progenitor(bob, ann).   progenitor(ann, zoe).
progenitor(tom, liz).   progenitor(liz, max).   progenitor(zoe, kim).
grandparent($X, $Z) :- progenitor($X, $Y), progenitor($Y, $Z).
forebear($X, $Y) :- progenitor($X, $Y).
forebear($X, $Z) :- progenitor($X, $Y), forebear($Y, $Z).
ancestor_of($X, $Y) :- parent_of($X, $Y).
ancestor_of($X, $Z) :- parent_of($X, $Y), ancestor_of($Y, $Z).
descendant_of($X, $Y) :- ancestor_of($Y, $X).
grandfather_of($X, $Z) :- parent_of($X, $Y), parent_of($Y, $Z).
parent_of(ann, tom).
parent_of(john, mary).
parent_of(john, peter).
parent_of(marco, luca).
parent_of(marco, sofia).
parent_of(mary, ann).
parent_of(paul, mary).
sibling_of($X, $Y) :- parent_of($P, $X), parent_of($P, $Y).

