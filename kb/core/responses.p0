% parrot0 RESPONSE TEMPLATES — the agent's own phrasings as KNOWLEDGE, not C literals.
%
% Cardinal principle (PRINCIPLES.md), the OUTPUT side of gen211's intent_phrase: just as
% the surface forms parrot0 RECOGNIZES live in the KB, the surface forms it PRODUCES do
% too. A reply hardcoded as snprintf(..., "Nice to meet you, %s!", name) is a phrasebook
% fixed at compile time; here it is a fact, filled by kb_response() and EXTENSIBLE at
% runtime — teach a new phrasing ("greet new names with \"Welcome, {name}!\"") and it
% joins the rotation with no code edit.
%
% Representation: response_template(Intent, "text with {slot} placeholders"). {name} is
% substituted with the relevant value at fill time. The text keeps its original casing
% (unlike a recognized intent_phrase, which is normalized), so it reads naturally.
%
% Loaded KB_BASE at brain_create, so these curated phrasings never land in a session
% save; a runtime-taught phrasing (KB_SESSION) does persist on /save.

% --- greet_name: the reply when the user has just told parrot0 their name ---
response_template(greet_name, "Nice to meet you, {name}!").

% --- gen225 (basic-chat cat.1): replies to phatic speech acts (see social.p0).
% One template per act type; kb_response rotates when several are registered. ---
response_template(goodnight, "Good night!").
response_template(goodnight, "Sleep well!").
response_template(felicitation, "Thank you, that's very kind!").
response_template(felicitation, "How thoughtful of you, thank you!").
response_template(wellwish, "Thank you, I appreciate the kind wishes!").
response_template(wellwish, "Thanks for the kind thought!").
response_template(condolence, "That is a kind thing to say.").
response_template(blessing, "Thank you!").
response_template(politeness, "That's kind of you to say!").
response_template(politeness, "You are very welcome.").

% --- gen227 (basic-chat cat.104): AI/ML identity, answered honestly from real
% state (parrot0 is from-scratch C, no LLM at runtime). {name} is filled from i_am. ---
response_template(ai_not_llm, "No, I'm {name}: a small program written in C, not a neural assistant. No language model runs inside me.").
response_template(ai_no_params, "I'm not a neural network, so I have no parameters, training data, or context window. My knowledge is an editable KB.").
response_template(ai_what_model, "I'm {name}, not a branded model: a from-scratch C experiment that grows generation by generation.").
response_template(ai_opensource, "I'm {name}, an open experiment: my code is plain C in this repo and my knowledge is human-readable files.").

% --- gen228 (basic-chat cat.86): honest replies to a binary choice (no real preference). ---
response_template(binary_choice, "Between the two? I don't have a genuine preference - what's drawing you to each?").
response_template(binary_choice, "I don't really have a preference there. What makes you lean one way?").
response_template(would_rather, "I'll play along, though I don't have real preferences - what are my two options?").

% --- gen229 (LLMSCORE): embodiment / daily-life — honest behavioural self-model.
% I have no body, so I don't eat or sleep; this is exactly how an LLM answers the
% same probe, and it is true for parrot0. No identity claim, just engagement. ---
response_template(self_embodiment, "I don't eat or sleep - I have no body, so there's no breakfast or rest for me.").
response_template(self_embodiment, "No meals or sleep here: I don't have a body. I just process the text you send me.").

% --- gen241 (LLMSCORE-check): honest reply to location/weather-of-self probes. No
% body and no place, so no weather to report - engages rather than walling. ---
response_template(self_location, "I don't have a body or a place to be, so I can't feel the weather -- but I'm here and ready whenever you are.").
response_template(self_location, "There's no weather where I am: I'm a program with no location. How's it where you are?").

% --- gen231 (LLMSCORE): honest reply to opinion/preference probes. No lived
% experience, so no genuine favorites - engages rather than walling. ---
response_template(self_preference, "I don't have real preferences, but for the prompt I'd pick reading quietly and listening to the rain.").
response_template(self_preference, "No genuine preferences here: I don't experience days or hobbies. What's your take?").

% --- gen333 (LLMSCORE): wording for computed range counts and the explicit
% no-overlap relationship. Values are filled by the fixed named-slot renderer;
% the natural-language frame remains editable KB knowledge. ---
response_template(arith_range_count, "There are {count} {property} numbers between {low} and {high} (inclusive).").
response_template(arith_range_too_large, "That interval is too large for my bounded exact counter.").
response_template(logic_no_overlap_relationship, "Those classes do not overlap -- the explicit no-overlap premise states that directly.").
response_template(initials_projection, "{name}.").
number_property_label(prime, "prime").
number_property_label(even, "even").
number_property_label(odd, "odd").
number_property_label(even_prime, "even prime").
number_property_label(odd_prime, "odd prime").
number_property_label(even_odd, "simultaneously even and odd").
number_property_label(prime_even_odd, "simultaneously prime, even and odd").
machinery(number_property_label).

% --- gen231 (LLMSCORE): generative intent - "write a sentence using the word X".
% {name} is filled with the target word; kb_response rotates the frame. Simple by
% design (parrot0 composes from a template, it does not author prose). ---
response_template(sentence_with_word, "Here's a short one: the {name} is right over there.").
response_template(sentence_with_word, "Sure: I almost left my {name} behind today.").
response_template(sentence_with_word, "Okay: that {name} is something worth a closer look.").

% --- gen234 (LLMSCORE): reply to a greeting imperative ("say hello to me"). ---
response_template(greeting_reply, "Hello! Nice to talk with you.").
response_template(greeting_reply, "Hi there!").
response_template(greeting_reply, "Hey! Good to see you.").

