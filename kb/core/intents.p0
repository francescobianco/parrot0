intent_cue(self_embodiment, "are you hungry").
intent_cue(self_embodiment, "did you sleep").
intent_cue(self_embodiment, "do you sleep").
intent_cue(self_embodiment, "are you tired").
intent_cue(self_embodiment, "do you dream").
intent_cue(self_embodiment, "per colazione").
intent_cue(self_embodiment, "cosa hai mangiato").
intent_cue(self_embodiment, "cosa mangi").
intent_cue(self_embodiment, "hai dormito").
intent_cue(self_embodiment, "sei stanco").

