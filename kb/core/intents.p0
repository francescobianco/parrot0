% gen356 (LLMSCORE-max): finite request acts share one semantic projection.
% The surface forms are KB vocabulary; semantic_summary/2 is a rule in
% procedures.p0 over wiki_concept/3. A new act form or topic alias is live data,
% while mod_answer_frame remains the unchanged universal binary-relation motor.
answer_frame("what is", semantic_summary).
answer_frame("what are", semantic_summary).
answer_frame("explain", semantic_summary).
answer_frame("describe", semantic_summary).
answer_frame("tell me about", semantic_summary).
answer_frame("concept of", semantic_summary).
answer_frame("significance", semantic_summary).
answer_frame("how would", semantic_summary).
answer_frame("how could", semantic_summary).
answer_frame("propose", semantic_summary).
answer_frame("design", semantic_summary).
% gen359 (LLMSCORE-max): more analytical frame verbs share the one projection.
% Each only ever fires the semantic answer when a KB topic actually resolves, so
% "why is the sky blue" (no topic) still reaches the causal engine, etc.
answer_frame("how does", semantic_summary).
answer_frame("how do", semantic_summary).
answer_frame("how did", semantic_summary).
answer_frame("how has", semantic_summary).
answer_frame("why do", semantic_summary).
answer_frame("why does", semantic_summary).
answer_frame("analyze", semantic_summary).
answer_frame("analyse", semantic_summary).
answer_frame("evaluate", semantic_summary).
answer_frame("discuss", semantic_summary).
