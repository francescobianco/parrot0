answer_frame("what engineering", semantic_summary).
answer_frame("what are the strongest", semantic_summary).

% gen358 (LLMSCORE foundation): bounded semantic projection. The universal
% evidence scorer selects one topic from teachable semantic_topic_cue/2 facts;
% the fixed answer-frame engine then reads a declared source once. Unknown
% topics therefore decline in bounded time instead of querying a recursive
% projection once per input token.
answer_projection(semantic_summary, semantic_topic_cue).
projection_source(semantic_summary, wiki_concept, ternary).
projection_source(semantic_summary, explanation, binary).
projection_source(semantic_summary, because, binary).

