% gen241/gen244 (LLMSCORE-check + NEXTMOVE): step-by-step procedures as ordered KB
% facts. process_topic/2 is the KB-side bridge from request words to a Task;
% process_step(Task, N, "step") is the content. Adding a task is just more facts --
% the C only selects by topic overlap, orders, and numbers the steps.
process_topic(tea, tea).
process_step(tea, 1, "Fill a kettle with fresh water and bring it to the boil").
process_step(tea, 2, "Put a tea bag (or loose tea in an infuser) into a cup or teapot").
process_step(tea, 3, "Pour the boiling water over the tea and let it steep for 3 to 5 minutes").
process_step(tea, 4, "Remove the tea bag or infuser").
process_step(tea, 5, "Add milk, sugar, or lemon to taste, stir, and serve").
process_topic(coffee, coffee).
process_step(coffee, 1, "Boil fresh water and let it cool for about thirty seconds").
process_step(coffee, 2, "Add ground coffee to a filter, press, or cafetiere").
process_step(coffee, 3, "Pour the hot water over the grounds and let it brew").
process_step(coffee, 4, "Pour into a cup, add milk or sugar to taste, and serve").
process_topic(bread_rise, bread).
process_topic(bread_rise, yeast).
process_topic(bread_rise, dough).
process_topic(bread_rise, rise).
process_topic(bread_rise, rises).
process_topic(bread_rise, rising).
process_step(bread_rise, 1, "Yeast consumes sugars in the dough and releases carbon dioxide gas").
process_step(bread_rise, 2, "Gluten strands trap that gas in small bubbles, stretching the dough").
process_step(bread_rise, 3, "Warmth and time let fermentation continue, so the bubbles expand").
process_step(bread_rise, 4, "During baking, the gas expands further and the crumb sets into a risen loaf").

