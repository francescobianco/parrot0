concise_topic(sky_blue, day).
concise_explain(sky_blue, 3, "air scatters blue").

% gen241 (LLMSCORE-check): four-line poems (quatrains). Each line is a separate
% poem4(Concept, "line") fact (KB atoms cap at 128 chars), kept in order; the C reads
% the four lines for the topic and joins them. "write a four-line poem about a
% lighthouse" selects by topic word (engine fixed, lexicon learns).
poem4(lighthouse, "Alone on the rock where the grey waves roam,").
poem4(lighthouse, "the lighthouse stands as the storm comes home.").
poem4(lighthouse, "Through wind and the dark and the breaking spray,").
poem4(lighthouse, "its steady beam keeps the night at bay.").
poem4(storm, "The sky goes black and the cold winds rise,").
poem4(storm, "the sea throws spray at the angry skies.").
poem4(storm, "But high on the cliff through the wind and rain,").
poem4(storm, "a single light holds watch again.").
poem4(sea, "The sea breathes slow in silver and grey,").
poem4(sea, "rolling its waves to the edge of day.").
poem4(sea, "It keeps the oldest song of them all --").
poem4(sea, "the long, low sound of the tide's rise and fall.").
poem4(ocean, "The ocean breathes in blue and grey,").
poem4(ocean, "and carries the moon on a silver way.").
poem4(ocean, "Its deep tides murmur, vast and wide,").
poem4(ocean, "with secret songs beneath the tide.").
poem4(robot, "A small steel hand reached into the rain,").
poem4(robot, "and felt the cold drops fall again and again.").
poem4(robot, "It had no word for the wonder it found,").
poem4(robot, "only the soft, bright, falling sound.").
poem4(rain, "The first drops tap on the windowpane,").
poem4(rain, "soft and grey comes the falling rain.").
poem4(rain, "It washes the dust from the tired street,").
poem4(rain, "and hums a tune that is cool and sweet.").

