magnitude_cue(lighter, weight, min).
magnitude_cue(faster, speed, max).
magnitude_cue(slower, speed, min).
magnitude_cue(closer, distance_from_sun, min).
magnitude_cue(nearer, distance_from_sun, min).
magnitude_cue(closest, distance_from_sun, min).
magnitude_cue(farther, distance_from_sun, max).
magnitude_cue(further, distance_from_sun, max).
magnitude_cue(farthest, distance_from_sun, max).
% gen310a: length/river superlatives
