% parrot0 WORLD FACTS — curated category membership as KNOWLEDGE, not C literals.
%
% gen230 (LLMSCORE behavioural resemblance). An LLM trivially "names a color that
% starts with B"; parrot0 can too, the honest KB-first way — the members live here
% as facts, and mod_namestart (20-math.c) reads the category + the target initial
% and returns the first known member. Add a category_member fact and the capability
% extends for free; nothing is hardcoded in C.
%
% NB: geography (capitals) was intentionally NOT added here — the `capital`
% predicate is owned by the curated analogy/fewshot/blankwall reasoning tests, which
% TEACH it at runtime; preloading base capital facts pollutes that machinery. So
% "capital of <country>" remains an honest, teachable gap for now.
%
% Members are single lowercase tokens (matching the canonicalized turn). Loaded
% KB_BASE and filtered from the user-fact count (is_internal_pred), so they are
% base substrate, never counted as facts the user taught.

category_member(color, blue).
category_member(color, black).
category_member(color, brown).
category_member(color, red).
category_member(color, orange).
category_member(color, yellow).
category_member(color, green).
category_member(color, purple).
category_member(color, pink).
category_member(color, white).
category_member(color, grey).
category_member(color, gold).
category_member(color, silver).
category_member(color, violet).
category_member(color, indigo).

category_member(animal, ant).
category_member(animal, bear).
category_member(animal, cat).
category_member(animal, dog).
category_member(animal, elephant).
category_member(animal, fox).
category_member(animal, goat).
category_member(animal, horse).
category_member(animal, iguana).
category_member(animal, jaguar).
category_member(animal, koala).
category_member(animal, lion).
category_member(animal, monkey).
category_member(animal, newt).
category_member(animal, owl).
category_member(animal, pig).
category_member(animal, rabbit).
category_member(animal, snake).
category_member(animal, tiger).
category_member(animal, wolf).
category_member(animal, zebra).

category_member(fruit, apple).
category_member(fruit, banana).
category_member(fruit, cherry).
category_member(fruit, date).
category_member(fruit, fig).
category_member(fruit, grape).
category_member(fruit, lemon).
category_member(fruit, mango).
category_member(fruit, orange).
category_member(fruit, peach).
category_member(fruit, pear).
category_member(fruit, plum).

% --- gen231: antonyms for "what's the opposite of <X>?" — answered by the existing
% gen11 relational query path (opposite(X, Y)). Stored BOTH directions (one clause
% per line: the .p0 reader is line-oriented) so the query always resolves. ---
opposite(hot, cold).
opposite(cold, hot).
opposite(big, small).
opposite(small, big).
opposite(tall, short).
opposite(short, tall).
opposite(fast, slow).
opposite(slow, fast).
opposite(high, low).
opposite(low, high).
opposite(up, down).
opposite(down, up).
opposite(left, right).
opposite(right, left).
opposite(open, closed).
opposite(closed, open).
opposite(light, dark).
opposite(dark, light).
opposite(day, night).
opposite(night, day).
opposite(happy, sad).
opposite(sad, happy).
opposite(good, bad).
opposite(bad, good).
opposite(true, false).
opposite(false, true).
opposite(yes, no).
opposite(no, yes).
opposite(young, old).
opposite(old, young).
opposite(full, empty).
opposite(empty, full).
opposite(wet, dry).
opposite(dry, wet).
opposite(hard, soft).
opposite(soft, hard).
opposite(strong, weak).
opposite(weak, strong).
opposite(rich, poor).
opposite(poor, rich).
opposite(early, late).
opposite(late, early).
opposite(win, lose).
opposite(lose, win).
opposite(love, hate).
opposite(hate, love).
opposite(more, less).
opposite(less, more).
opposite(first, last).
opposite(last, first).
opposite(near, far).
opposite(far, near).
opposite(clean, dirty).
opposite(dirty, clean).

% --- gen231: canonical colours of familiar things for "what color is a banana?"
% (mod_knowledge recognizer queries color_of/2). One ground colour each; a thing
% with several real colours just records its prototypical one, honestly partial. ---
color_of(banana, yellow).
color_of(lemon, yellow).
color_of(sun, yellow).
color_of(apple, red).
color_of(cherry, red).
color_of(strawberry, red).
color_of(tomato, red).
color_of(blood, red).
color_of(grass, green).
color_of(lime, green).
color_of(leaf, green).
color_of(emerald, green).
color_of(sky, blue).
color_of(sea, blue).
color_of(ocean, blue).
color_of(orange, orange).
color_of(carrot, orange).
color_of(grape, purple).
color_of(eggplant, purple).
color_of(snow, white).
color_of(milk, white).
color_of(cloud, white).
color_of(coal, black).
color_of(night, black).
color_of(chocolate, brown).
color_of(wood, brown).
color_of(soil, brown).
