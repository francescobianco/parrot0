% gen240 (LLMSCORE): compound-word riddles. compound_word(First, Second, Whole) —
% "the word that follows fire and precedes place" -> fireplace.
compound_word(fire, place, fireplace).
compound_word(fire, fly, firefly).
compound_word(fire, work, firework).
compound_word(fire, wood, firewood).
compound_word(sun, flower, sunflower).
compound_word(sun, shine, sunshine).
compound_word(sun, light, sunlight).
compound_word(rain, bow, rainbow).
compound_word(rain, coat, raincoat).
compound_word(water, fall, waterfall).
compound_word(foot, ball, football).
compound_word(book, case, bookcase).
compound_word(news, paper, newspaper).
compound_word(snow, flake, snowflake).
compound_word(moon, light, moonlight).
compound_word(bed, room, bedroom).

% --- gen240 (LLMSCORE): parametric haiku. A haiku is a fixed 5-7-5 structure;
% the poetic image LINES are KB knowledge, pre-syllable-counted, one per concept
% per slot (open=5, mid=7, close=5). The C assembler weaves open(subject) /
% mid(object) / close(subject), so teaching a new concept's three lines extends
% the generator with no code edit (PRINCIPLES.md: engine fixed, lexicon learns).
% gen254: technology and autumn, so paired-theme prompts ("autumn and
% technology") can weave open(subj)/mid(obj)/close(subj) across both.
haiku_open(technology, "A screen glows at dusk").
haiku_mid(technology, "small lights think in the still house").
haiku_close(technology, "the machine dreams on").
haiku_open(ocean, "Ocean breathes at dawn").
haiku_mid(ocean, "silver waves carry the sun").
haiku_close(ocean, "gulls write on the wind").
haiku_open(robot, "A small metal hand").
haiku_mid(robot, "circuits hum with new questions").
haiku_close(robot, "steel learns how to feel").
haiku_open(rain, "First drops on the roof").
haiku_mid(rain, "cold silver falling from grey").
haiku_close(rain, "the dry world drinks deep").
haiku_open(moon, "Pale lantern of night").
haiku_mid(moon, "drifting over silent fields").
haiku_close(moon, "shadows softly bloom").
haiku_open(autumn, "Red leaves let go now").
haiku_mid(autumn, "the wind carries them away").
haiku_close(autumn, "bare branches stay still").
% gen240: broader haiku lexicon so more requested themes compose (engine fixed).
haiku_open(lamp, "A lamp's quiet glow").
haiku_mid(lamp, "holds back the dark of the night").
haiku_close(lamp, "a small warm island").
haiku_open(book, "Pages hold their breath").
haiku_mid(book, "worlds asleep between the lines").
haiku_close(book, "waiting to be read").
haiku_open(star, "One star pricks the dusk").
haiku_mid(star, "old light crossing endless dark").
haiku_close(star, "older than our eyes").
haiku_open(tree, "The old tree stands still").
haiku_mid(tree, "roots deep, branches in the wind").
haiku_close(tree, "holding up the sky").
haiku_open(river, "The river moves on").
haiku_mid(river, "carrying the sky downstream").
haiku_close(river, "never the same twice").
haiku_open(snow, "Snow falls without sound").
haiku_mid(snow, "the world grows quiet and white").
haiku_close(snow, "footprints fill again").
haiku_open(fire, "Small flame in the dark").
haiku_mid(fire, "it eats the night and gives warmth").
haiku_close(fire, "ash by the morning").
haiku_open(mountain, "The mountain is still").
haiku_mid(mountain, "clouds rest upon its grey peak").
haiku_close(mountain, "older than the sea").
haiku_open(cat, "The cat folds itself").
haiku_mid(cat, "into a circle of sleep").
haiku_close(cat, "one eye half open").
haiku_open(bird, "A bird tilts its head").
haiku_mid(bird, "the whole sky waiting for it").
haiku_close(bird, "then it lifts and goes").
haiku_open(candle, "One candle burning").
haiku_mid(candle, "a small gold tent in the dark").
haiku_close(candle, "it gives all it has").
haiku_open(friendship, "Two strangers, one bench").
haiku_mid(friendship, "slowly the silence grows warm").
haiku_close(friendship, "neither leaves alone").
haiku_open(spring, "Green pushes through mud").
haiku_mid(spring, "the cold earth remembers warmth").
haiku_close(spring, "everything begins").
haiku_open(winter, "The world holds its breath").
haiku_mid(winter, "bare trees against a grey sky").
haiku_close(winter, "waiting for the thaw").
haiku_open(silence, "After the last word").
haiku_mid(silence, "the room settles into hush").
haiku_close(silence, "even time slows down").
haiku_open(love, "Two hands find each other").
haiku_mid(love, "the whole noisy world goes quiet").
haiku_close(love, "no need left to speak").
haiku_open(time, "The river of hours").
haiku_mid(time, "carries each moment downstream").
haiku_close(time, "none of them return").
haiku_open(home, "A light in the window").
haiku_mid(home, "the long road finally ends").
haiku_close(home, "the door knows your name").
haiku_open(dream, "Sleep opens a door").
haiku_mid(dream, "strange rivers run through the dark").
haiku_close(dream, "dawn erases them").
haiku_open(hope, "A small green shoot waits").
haiku_mid(hope, "under the last of the snow").
haiku_close(hope, "sure of the warm sun").

