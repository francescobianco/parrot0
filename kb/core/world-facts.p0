% parrot0 WORLD FACTS — curated category membership as KNOWLEDGE, not C literals.
%
% gen230 (LLMSCORE behavioural resemblance). An LLM trivially "names a color that
% starts with B"; parrot0 can too, the honest KB-first way — the members live here
% as facts, and mod_namestart (20-math.c) reads the category + the target initial
% and returns the first known member. Add a category_member fact and the capability
% extends for free; nothing is hardcoded in C.
%
% NB: geography (capitals) was intentionally NOT added here — the `capital`
% predicate is owned by the curated analogy/fewshot/blankwall reasoning tests, which
% TEACH it at runtime; preloading base capital facts pollutes that machinery. So
% "capital of <country>" remains an honest, teachable gap for now.
%
% Members are single lowercase tokens (matching the canonicalized turn). Loaded
% KB_BASE and filtered from the user-fact count (is_internal_pred), so they are
% base substrate, never counted as facts the user taught.

category_member(color, blue).
category_member(color, black).
category_member(color, brown).
category_member(color, red).
category_member(color, orange).
category_member(color, yellow).
category_member(color, green).
category_member(color, purple).
category_member(color, pink).
category_member(color, white).
category_member(color, grey).
category_member(color, gold).
category_member(color, silver).
category_member(color, violet).
category_member(color, indigo).

category_member(animal, ant).
category_member(animal, bear).
category_member(animal, cat).
category_member(animal, dog).
category_member(animal, elephant).
category_member(animal, fox).
category_member(animal, goat).
category_member(animal, horse).
category_member(animal, iguana).
category_member(animal, jaguar).
category_member(animal, koala).
category_member(animal, lion).
category_member(animal, monkey).
category_member(animal, newt).
category_member(animal, owl).
category_member(animal, pig).
category_member(animal, rabbit).
category_member(animal, snake).
category_member(animal, tiger).
category_member(animal, wolf).
category_member(animal, zebra).

category_member(fruit, apple).
category_member(fruit, banana).
category_member(fruit, cherry).
category_member(fruit, date).
category_member(fruit, fig).
category_member(fruit, grape).
category_member(fruit, lemon).
category_member(fruit, mango).
category_member(fruit, orange).
category_member(fruit, peach).
category_member(fruit, pear).
category_member(fruit, plum).
category_member(country, andorra).
category_member(country, france).
category_member(country, spain).
category_member(country, italy).
category_member(country, germany).
category_member(country, japan).
category_member(country, canada).
category_member(country, united_states).
category_member(country, united_kingdom).
category_member(country, australia).


% --- gen231: antonyms for "what's the opposite of <X>?" — answered by the existing
% gen11 relational query path (opposite(X, Y)). Stored BOTH directions (one clause
% per line: the .p0 reader is line-oriented) so the query always resolves. ---
opposite(hot, cold).
opposite(cold, hot).
opposite(big, small).
opposite(small, big).
opposite(tall, short).
opposite(short, tall).
opposite(fast, slow).
opposite(slow, fast).
opposite(high, low).
opposite(low, high).
opposite(up, down).
opposite(down, up).
opposite(left, right).
opposite(right, left).
opposite(open, closed).
opposite(closed, open).
opposite(light, dark).
opposite(dark, light).
opposite(day, night).
opposite(night, day).
opposite(happy, sad).
opposite(sad, happy).
opposite(good, bad).
opposite(bad, good).
opposite(true, false).
opposite(false, true).
opposite(yes, no).
opposite(no, yes).
opposite(young, old).
opposite(old, young).
opposite(full, empty).
opposite(empty, full).
opposite(wet, dry).
opposite(dry, wet).
opposite(hard, soft).
opposite(soft, hard).
opposite(strong, weak).
opposite(weak, strong).
opposite(rich, poor).
opposite(poor, rich).
opposite(early, late).
opposite(late, early).
opposite(win, lose).
opposite(lose, win).
opposite(love, hate).
opposite(hate, love).
opposite(more, less).
opposite(less, more).
opposite(first, last).
opposite(last, first).
opposite(near, far).
opposite(far, near).
opposite(clean, dirty).
opposite(dirty, clean).

% --- gen231: canonical colours of familiar things for "what color is a banana?"
% (mod_knowledge recognizer queries color_of/2). One ground colour each; a thing
% with several real colours just records its prototypical one, honestly partial. ---
color_of(banana, yellow).
color_of(lemon, yellow).
color_of(sun, yellow).
color_of(apple, red).
color_of(cherry, red).
color_of(strawberry, red).
color_of(tomato, red).
color_of(blood, red).
color_of(grass, green).
color_of(lime, green).
color_of(leaf, green).
color_of(emerald, green).
color_of(sky, blue).
color_of(sea, blue).
color_of(ocean, blue).
color_of(orange, orange).
color_of(carrot, orange).
color_of(grape, purple).
color_of(eggplant, purple).
color_of(snow, white).
color_of(milk, white).
color_of(cloud, white).
color_of(coal, black).
color_of(night, black).
color_of(chocolate, brown).
color_of(wood, brown).
color_of(soil, brown).

% --- gen232 (LLMSCORE #5): causal sentence-completion knowledge. "complete this
% sentence: the sky is blue because..." / "why is the sky blue?" -> the reason from
% because/2. The key is the content words of the clause joined subject_adjective
% (sky_blue); the value is the reason clause (quoted, may contain commas). This is
% a completion grounded in KNOWLEDGE; an unknown clause is admitted, not invented. ---
because(sky_blue, "sunlight scatters off the air, and blue light scatters the most").
because(sea_blue, "water absorbs red light and reflects blue back").
because(ocean_blue, "water absorbs red light and reflects blue back").
because(grass_green, "it contains chlorophyll, which reflects green light").
because(leaves_green, "they contain chlorophyll, which reflects green light").
because(plants_green, "they contain chlorophyll, which reflects green light").
because(fire_hot, "burning releases stored chemical energy as heat").
because(sun_hot, "nuclear fusion in its core releases enormous energy").
because(ice_cold, "its molecules have given up most of their heat energy").
because(snow_white, "it reflects all colours of light about equally").
because(night_dark, "the sun is below the horizon, so its light cannot reach us").
because(sun_bright, "it releases vast energy as light from nuclear fusion").
because(birds_fly, "their wings and light bodies let them push against the air").

% --- gen233 (kb-first manifesto, worked example #4): QUALITATIVE-CHANGE reasoning.
% grows_with(Feature, Base): Feature increases when Base's size increases (co-monotone;
% chained transitively in C). increases(Action, Source): the action makes more Source.
% Together they let "if knowledge is like a circle, what happens to its circumference
% when you learn?" be DEDUCED (more knowledge -> bigger circle -> bigger circumference),
% not generated. See docs/plans/kb-first.md. ---
grows_with(circumference, circle).
grows_with(area, circle).
grows_with(radius, circle).
grows_with(diameter, circle).
grows_with(perimeter, circle).
grows_with(surface, sphere).
grows_with(volume, sphere).
grows_with(branches, tree).
grows_with(leaves, tree).
grows_with(height, tree).
grows_with(flame, fire).
grows_with(heat, fire).

increases(learn, knowledge).
increases(study, knowledge).
increases(read, knowledge).
increases(practice, skill).
increases(train, skill).
increases(exercise, strength).
increases(grow, tree).
increases(age, tree).
% --- gen235 (LLMSCORE): common geography separated from teachable capital/2.
% `capital/2` remains available for analogy/few-shot learning; direct world
% questions use this curated substrate first.
capital_of_country(paris, france).
capital_of_country(rome, italy).
capital_of_country(berlin, germany).
capital_of_country(madrid, spain).
capital_of_country(london, united_kingdom).
capital_of_country(washington_dc, united_states).
capital_of_country(tokyo, japan).
capital_of_country(ottawa, canada).
capital_of_country(canberra, australia).

% --- gen239 (kb-first manifesto): island nations have no land-bordering
% countries. Explicit negative fact — closed-world absence would have implied
% "I don't know" rather than "zero"; we want the certitude behind a real
% curated claim, exactly as for `borders/2`. Substrate (is_struct_pred +
% is_internal_pred), so it never contaminates "how many facts do you know?". ---
no_land_border(australia).
no_land_border(japan).
no_land_border(united_kingdom).

% --- gen239 (kb-first manifesto): paint/colour mixing as KNOWLEDGE, not a C
% literal. Symmetric commutative pairs are stored both directions (the .p0
% reader is line-oriented) so mixes_to(X, Y, Z) resolves regardless of order. A
% new pair is DATA: add a fact and the mix recognizer (mod_knowledge) extends
% with no code edit. ---
paint_mix(blue, yellow, green).
paint_mix(yellow, blue, green).
paint_mix(red, yellow, orange).
paint_mix(yellow, red, orange).
paint_mix(blue, red, purple).
paint_mix(red, blue, purple).
paint_mix(white, black, grey).
paint_mix(black, white, grey).

% --- gen239 (kb-first manifesto): a few more land borders so "name two
% countries that border X" stays answerable beyond the andorra example. ---
borders(italy, france).
borders(italy, austria).
borders(italy, slovenia).
borders(italy, switzerland).
borders(france, spain).
borders(france, italy).
borders(france, germany).
borders(spain, france).
borders(spain, andorra).
borders(germany, france).
borders(germany, italy).

% --- gen235 (LLMSCORE): kind-level taxonomy for generic questions like
% "is a dog a mammal or a reptile?" Kept separate from entity facts y(x).
kind_is(dog, mammal).
kind_is(cat, mammal).
kind_is(horse, mammal).
kind_is(whale, mammal).
kind_is(snake, reptile).
kind_is(lizard, reptile).
kind_is(turtle, reptile).
kind_is(frog, amphibian).
kind_is(eagle, bird).
kind_is(salmon, fish).

% --- gen235 (LLMSCORE): tiny narrative continuation substrate.
scene_cue(clock, silence).
scene_cue(ticking, silence).
scene_cue(stopped, silence).
scene_cue(candle, darkness).
scene_cue(storm, suspense).
scene_cue(door, suspense).
continuation_template(silence, "the whole room held its breath").
continuation_template(silence, "every small sound in the house became enormous").
continuation_template(silence, "the stopped clock seemed to be waiting for an answer").
continuation_template(darkness, "the shadows seemed to lean closer").
continuation_template(suspense, "someone knocked once from the other side").

% --- gen235 (LLMSCORE): historically grounded guest-list substrate.
historical_figure(einstein).
figure_domain(einstein, science).
figure_reason(einstein, "to ask how he learned to think about space and time").
historical_figure(socrates).
figure_domain(socrates, philosophy).
figure_reason(socrates, "to press every easy answer with better questions").
historical_figure(cleopatra).
figure_domain(cleopatra, leadership).
figure_reason(cleopatra, "to hear how power, diplomacy, and survival looked from her side").
% --- gen236 (LLMSCORE): small lexical/physical commons.
synonym(happy, glad).
synonym(sad, unhappy).
synonym(big, large).
synonym(small, little).
very_cold_result(water, "it freezes into ice").

% One-line couplet surfaces as KB output; C only selects by topic.
response_template(couplet_ai, "Silicon minds trace patterns in the night; human questions teach their borrowed light.").

% Minimal ES lexicon for short translation prompts.
tr_es(cat, gato).
tr_es(dog, perro).
tr_es(table, mesa).
tr_es(good, buenos).
tr_es(morning, días).
tr_es(water, agua).
tr_es(the, el).
tr_es(is, esta).
tr_es(on, en).
