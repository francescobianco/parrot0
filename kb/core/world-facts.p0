% --- gen235 (LLMSCORE): tiny narrative continuation substrate.
scene_cue(clock, silence).
scene_cue(ticking, silence).
scene_cue(stopped, silence).
scene_cue(candle, darkness).
scene_cue(storm, suspense).
scene_cue(door, suspense).
continuation_template(silence, "the whole room held its breath").
continuation_template(silence, "every small sound in the house became enormous").
continuation_template(silence, "the stopped clock seemed to be waiting for an answer").
continuation_template(darkness, "the shadows seemed to lean closer").
continuation_template(suspense, "someone knocked once from the other side").
% --- gen240 (LLMSCORE): more scene cues so common story openings continue.
scene_cue(house, mystery).
scene_cue(street, mystery).
scene_cue(hallway, mystery).
scene_cue(earthquake, suspense).
scene_cue(night, suspense).
scene_cue(rainbow, wonder).
scene_cue(valley, wonder).
scene_cue(sky, wonder).
continuation_template(mystery, "no one had set foot inside for as long as anyone could remember").
continuation_template(mystery, "a single light flickered in an upstairs window").
continuation_template(mystery, "the neighbours always crossed to the other side before passing it").
continuation_template(wonder, "the colours spilled down until they touched the grass").
continuation_template(wonder, "every face turned upward, caught in the same quiet awe").
continuation_template(wonder, "for a moment the whole valley seemed to hold its breath").
% gen240: a lone watcher / lookout scene (lighthouse, cliff, shore, tower).
scene_cue(lighthouse, vigil).
scene_cue(cliff, vigil).
scene_cue(shore, vigil).
scene_cue(tower, vigil).
scene_cue(watching, vigil).
