category_member(animal, dog).
category_member(animal, elephant).
category_member(animal, fox).
category_member(animal, goat).
category_member(animal, horse).
category_member(animal, iguana).
category_member(animal, jaguar).
category_member(animal, koala).
category_member(animal, lion).
category_member(animal, monkey).
category_member(animal, newt).
category_member(animal, owl).
category_member(animal, pig).
category_member(animal, rabbit).
category_member(animal, snake).
category_member(animal, tiger).
category_member(animal, wolf).
category_member(animal, zebra).

