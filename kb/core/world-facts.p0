% gen308: autolearn's verified knowledge, made OFFICIAL (F.'s directive: what
% autolearn learns must be committed as project knowledge). These closed
% "engine_gap" entries in kb/learning/autolearn-ledger.jsonl by pairing a taught
% relation with an answer_frame/2 (gen306) — the CONSUMER-gap reduction: the fact
% alone was inert; the frame makes the question form answerable, no C module.
% Distributed here from the scratch file kb/learning/autolearn.p0 (now deleted);
% chemical_symbol was normalized to one canonical order (Symbol, Element) — the
% scratch file had both directions — and deduplicated.
chemical_symbol(h, hydrogen).
chemical_symbol(he, helium).
chemical_symbol(li, lithium).
chemical_symbol(be, beryllium).
chemical_symbol(b, boron).
chemical_symbol(c, carbon).
chemical_symbol(n, nitrogen).
chemical_symbol(o, oxygen).
chemical_symbol(f, fluorine).
chemical_symbol(ne, neon).
chemical_symbol(na, sodium).
chemical_symbol(mg, magnesium).
chemical_symbol(al, aluminium).
chemical_symbol(si, silicon).
chemical_symbol(p, phosphorus).
chemical_symbol(s, sulfur).
chemical_symbol(cl, chlorine).
chemical_symbol(ar, argon).
chemical_symbol(k, potassium).
chemical_symbol(ca, calcium).
chemical_symbol(fe, iron).
chemical_symbol(cu, copper).
chemical_symbol(zn, zinc).
chemical_symbol(ag, silver).
chemical_symbol(au, gold).
chemical_symbol(hg, mercury).
chemical_symbol(pb, lead).
answer_frame("symbol", chemical_symbol).
answer_frame("short for", chemical_symbol).
% the only mammal capable of true flight (bats). rel + answer_frame so the
% "what is the only mammal capable of true flight?" phrasing is answerable.
mammal_true_flight(bat, mammal).
answer_frame("true flight", mammal_true_flight).
% capital_on_river(Capital, River): which capital a river runs through.
capital_on_river(cairo, nile).
capital_on_river(khartoum, nile).
% gen309: more rivers so the SUPERLATIVE aggregation is meaningful (the Danube
% flows through 4 national capitals, the most of any river in the world).
capital_on_river(vienna, danube).
capital_on_river(bratislava, danube).
capital_on_river(budapest, danube).
capital_on_river(belgrade, danube).
capital_on_river(london, thames).
capital_on_river(paris, seine).
capital_on_river(rome, tiber).
capital_on_river(berlin, spree).
answer_frame("river", capital_on_river).
% "which river runs through the most capital cities?" — a fold over the relation:
% group by River (second arg), count capitals, take the max. aggregate_frame is
% the teachable datum; mod_aggregate supplies only the bounded counting.
aggregate_frame("most capital", capital_on_river, second, max).
% hardest_natural_substance(Substance, Where); the frame answers "what is the
% hardest natural substance on earth?" via the word "earth" -> diamond.
hardest_natural_substance(diamond, earth).
answer_frame("hardest", hardest_natural_substance).
