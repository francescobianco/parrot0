% --- gen254: defining-phrase vocabulary — word_for(KeyPhrase, Word). The phrase
% is matched as a substring of the turn (like idiom_meaning), so "what word
% describes a person who always tells the truth?" resolves without quoting.
% Teaching a new entry is one fact, no code edit. ---
word_for("always tells the truth", honest).
word_for("never tells the truth", dishonest).
word_for("never gives up", persistent).
word_for("always arrives on time", punctual).
word_for("always on time", punctual).
word_for("talks a lot", talkative).
word_for("is afraid of nothing", fearless).
word_for("fears nothing", fearless).
word_for("cannot read or write", illiterate).
word_for("can read and write", literate).
word_for("eats no meat", vegetarian).
word_for("eats only plants", herbivore).
word_for("eats both plants and meat", omnivore).
word_for("eats only meat", carnivore).
word_for("studies the stars", astronomer).
word_for("studies living things", biologist).
word_for("writes books", author).
word_for("collects stamps", philatelist).
word_for("loves books", "an avid reader").
word_for("speaks two languages", bilingual).
word_for("speaks many languages", polyglot).
word_for("works without pay", volunteer).
word_for("fear of heights", acrophobia).
word_for("fear of enclosed spaces", claustrophobia).
word_for("fear of spiders", arachnophobia).
word_for("thinks only of themselves", selfish).
word_for("gives freely to others", generous).
word_for("keeps a secret", discreet).
word_for("uses the left hand", "left-handed").

