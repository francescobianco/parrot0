continuation_template(aspiration, "finally start the project I keep putting off").
continuation_template(aspiration, "learn something I have never tried before").
continuation_template(aspiration, "spend the whole day outdoors with friends").
continuation_template(bottle, "e one golden afternoon, I would keep it for a grey day").
continuation_template(darkness, "the shadows seemed to lean closer").
continuation_template(enchanted, "a low hum filled the room as the dust lifted into the air").
continuation_template(enchanted, "its pages began to glow with a soft golden light").
continuation_template(enchanted, "words rose off the page and hung shimmering in the dark").
continuation_template(horizon, "that he no longer knew which way led home").
continuation_template(horizon, "that the distant lights were not stars but windows").
continuation_template(horizon, "that the road behind him had vanished into the dark").
continuation_template(magical, "fill with flowers that had never bloomed before").
continuation_template(magical, "hum with a quiet music no one could place").
continuation_template(magical, "shimmer with a soft silver light").
continuation_template(melody, "be missing one of its oldest comforts").
continuation_template(melody, "feel a great deal quieter and greyer").
continuation_template(melody, "lose much of its colour and its joy").
continuation_template(mystery, "a single light flickered in an upstairs window").
continuation_template(mystery, "no one had set foot inside for as long as anyone could remember").
continuation_template(mystery, "the neighbours always crossed to the other side before passing it").
continuation_template(mystery_box, "a tiny clockwork bird with emerald eyes").
continuation_template(rainfall, "rings widen where each drop lands").
continuation_template(rainfall, "somewhere under the reeds a frog answers").
continuation_template(rainfall, "the water wears a coat of silver circles").
continuation_template(reveal, "a dusty hallway bathed in pale candlelight").
continuation_template(reveal_next, "At the far end, a small brass key glinted on the floor").
continuation_template(silence, "every small sound in the house became enormous").
continuation_template(silence, "the stopped clock seemed to be waiting for an answer").
continuation_template(silence, "the whole room held its breath").
continuation_template(suspense, "a cold wind rushed in carrying the smell of rain").
continuation_template(suspense, "a narrow stairway curved down into the dark").
continuation_template(suspense, "someone knocked once from the other side").
continuation_template(vigil, "a faint light blinked far out on the dark water").
continuation_template(vigil, "a wave struck the rocks below with a sound like thunder").
continuation_template(vigil, "the beam swept once more across the empty, churning sea").
continuation_template(voyage, "felt the first pale light touch the rail").
continuation_template(voyage, "listened for the tide beneath the boards").
continuation_template(voyage, "watched the harbour lights fade behind him").
continuation_template(wonder, "every face turned upward, caught in the same quiet awe").
continuation_template(wonder, "for a moment the whole valley seemed to hold its breath").
continuation_template(wonder, "the colours spilled down until they touched the grass").
couplet(afternoon, "Grey is the sky and the rain won't cease; the dripping afternoon hums soft with peace.").
couplet(ai, "Silicon minds trace patterns in the night; human questions teach their borrowed light.").
couplet(autumn, "Autumn leaves fall over letters left unread; forgotten words sleep softly in their bed.").
couplet(cat, "The cat curls small against the failing light; it keeps one slow green eye upon the night.").
couplet(coder, "A weary coder sips the dark roast deep; the bugs retreat, the passing tests they keep.").
couplet(coffee, "Dark in the cup and bitter to the brim; one quiet sip and dawn no longer dim.").
couplet(library, "The quiet library keeps the dust of light; its pages bloom like lanterns in the night.").
couplet(lighthouse, "Alone it stands where wind and grey waves roam; a single faithful light to guide ships home.").
couplet(moon, "The pale moon climbs and spills its quiet light; it lays a silver road across the night.").
couplet(moonlight, "Moonlight trembles where the dark waves gleam; water holds the sky as if in dream.").
couplet(ocean, "The ocean rolls in silver and in foam; it sings the oldest song of going home.").
couplet(programmer, "A weary coder sips the dark roast deep; the bugs retreat, the passing tests they keep.").
couplet(rain, "Grey is the sky and the rain won't cease; the dripping afternoon hums soft with peace.").
couplet(rainy, "Grey is the sky and the rain won't cease; the dripping afternoon hums soft with peace.").
couplet(robot, "A robot meets the rain for the very first time; each cold bright drop a small uncharted rhyme.").
couplet(sea, "The sea rolls in with silver and with foam; it sings the oldest song of going home.").
couplet(snow, "The snow comes down and hushes all the street; it lays a quiet blanket, cold and sweet.").
couplet(spring, "The first green shoot pushes through cold black ground; in silence all the waking world is found.").
couplet(star, "A single star pricks through the dusk's last glow; old light still travelling from long ago.").
couplet(storm, "The storm may roar and fling the grey waves wide; the steady beam keeps watch through wind and tide.").
couplet(water, "Moonlight trembles where the dark waves gleam; water holds the sky as if in dream.").
cries($X) :- emits($X, $W), is_like($W, crying).
