landmark_of(japan, "Mount Fuji").
landmark_of(germany, "the Brandenburg Gate").
landmark_of(spain, "the Sagrada Familia").
landmark_of(canada, "the CN Tower").
landmark_of(egypt, "the Great Pyramids of Giza").
landmark_of(india, "the Taj Mahal").
landmark_of(china, "the Great Wall").

% --- gen240 (LLMSCORE): solar-system superlatives. planet_superlative(Property,
% Planet, "descriptive phrase") is the knowledge; the C maps a cue word in the
% question to the Property and reads the phrase (engine fixed, lexicon grows).
planet_superlative(closest_to_sun, mercury, "closest to the Sun").
planet_superlative(largest, jupiter, "the largest planet in our solar system").
planet_superlative(smallest, mercury, "the smallest planet in our solar system").
planet_superlative(hottest, venus, "the hottest planet").
planet_superlative(farthest_from_sun, neptune, "the farthest planet from the Sun").
planet_superlative(red_planet, mars, "the Red Planet").

% --- gen239 (kb-first manifesto): island nations have no land-bordering
% countries. Explicit negative fact — closed-world absence would have implied
% "I don't know" rather than "zero"; we want the certitude behind a real
% curated claim, exactly as for `borders/2`. Substrate (is_struct_pred +
% is_internal_pred), so it never contaminates "how many facts do you know?". ---
no_land_border(australia).
no_land_border(japan).
no_land_border(united_kingdom).

% --- gen239 (kb-first manifesto): paint/colour mixing as KNOWLEDGE, not a C
% literal. Symmetric commutative pairs are stored both directions (the .p0
% reader is line-oriented) so mixes_to(X, Y, Z) resolves regardless of order. A
% new pair is DATA: add a fact and the mix recognizer (mod_knowledge) extends
% with no code edit. ---
paint_mix(blue, yellow, green).
paint_mix(yellow, blue, green).
paint_mix(red, yellow, orange).
paint_mix(yellow, red, orange).
paint_mix(blue, red, purple).
paint_mix(red, blue, purple).
paint_mix(white, black, grey).
paint_mix(black, white, grey).

