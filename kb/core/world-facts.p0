% gen240 (LLMSCORE): parrot0 has no real preferences, but when asked to pick a
% favourite it offers one honestly rather than dodging. The pick is KB data.
default_color(blue).

% gen240 (LLMSCORE): appearance/2 lets parrot0 DESCRIBE something it cannot see.
% Asked "describe what a sunset looks like", it admits it has no senses but gives
% the description from KB knowledge (engine fixed, lexicon grows).
appearance(sunset, "the sky glows in bands of orange, pink, and deep red as the sun sinks below the horizon and the light slowly fades into dusk").
appearance(sunrise, "the dark sky brightens with soft gold and rose as the sun edges over the horizon and daylight returns").
appearance(rainbow, "a wide arc of colour -- red, orange, yellow, green, blue, and violet -- that appears when sunlight shines through rain").
appearance(ocean, "a vast expanse of blue-green water reaching to the horizon, its surface forever moving in waves").
appearance(snow, "soft white flakes that settle into a smooth, bright blanket covering everything in quiet").
appearance(forest, "tall trees crowded together, green light filtering through the leaves onto a floor of moss and fallen branches").

response_template(joke_chicken, "To get to the other side.").

% --- gen240 (LLMSCORE): parametric haiku. A haiku is a fixed 5-7-5 structure;
% the poetic image LINES are KB knowledge, pre-syllable-counted, one per concept
% per slot (open=5, mid=7, close=5). The C assembler weaves open(subject) /
% mid(object) / close(subject), so teaching a new concept's three lines extends
% the generator with no code edit (PRINCIPLES.md: engine fixed, lexicon learns).
haiku_open(ocean, "Ocean breathes at dawn").
haiku_mid(ocean, "silver waves carry the sun").
haiku_close(ocean, "gulls write on the wind").
haiku_open(robot, "A small metal hand").
haiku_mid(robot, "circuits hum with new questions").
haiku_close(robot, "steel learns how to feel").
haiku_open(rain, "First drops on the roof").
haiku_mid(rain, "cold silver falling from grey").
haiku_close(rain, "the dry world drinks deep").
haiku_open(moon, "Pale lantern of night").
haiku_mid(moon, "drifting over silent fields").
haiku_close(moon, "shadows softly bloom").
haiku_open(autumn, "Red leaves let go now").
haiku_mid(autumn, "the wind carries them away").
haiku_close(autumn, "bare branches stay still").

gender_es(gato, m).
gender_es(perro, m).
gender_es(mesa, f).
gender_es(agua, f).


