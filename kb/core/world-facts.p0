borders(andorra, france).
borders(andorra, spain).
borders_both(andorra, france, spain).
borders_both(andorra, spain, france).

color_of(school_bus, yellow).
color_of(bus, yellow).

response_template(haiku_ocean, "Ocean breathes at dawn / silver waves carry the sun / gulls write on the wind.").
response_template(joke_chicken, "To get to the other side.").

gender_es(gato, m).
gender_es(perro, m).
gender_es(mesa, f).
