% ── MESH-KNOWLEDGE (gen335) ──────────────────────────────────────────────────────
% Conoscenza di ORDINE SUPERIORE cresciuta sulla learning mesh (teacher LLM →
% parrot0 → parrot0 su una KB unica). Vedi docs/plans/learning-mesh.md.
%
% Un fatto aggiunge una foglia; un OPERATORE (regola n-aria) aggiunge una FUNZIONE
% sui fatti — N fatti sotto un operatore → O(chiusura) conclusioni derivabili.
%
% ⚠️ SCOPERTA (gen335, non ripassarci): una closure transitiva scritta come
%    p($X,$Z) :- p($X,$Y), p($Y,$Z).   (STESSO predicato, LEFT-recursive)
% manda l'SLD in ricorsione patologica (timeout), soprattutto se la regola precede
% i fatti. La forma ROBUSTA è una closure a PREDICATO SEPARATO, RIGHT-recursive, col
% primo goal del corpo che è un FATTO (un passo della relazione base):
%    closure($X,$Y) :- base($X,$Y).
%    closure($X,$Z) :- base($X,$Y), closure($Y,$Z).
% E i FATTI vanno PRIMA delle regole nel file. (Vedi docs/prolog-like-engine.md §5.)
%
% Nomi di predicato freschi: kb_match (lettore di answer_frame) si impianta sui
% predicati con regole (MESH-L5), quindi gli answer_frame stanno solo su predicati
% PIATTI (paternità, geografia), dove il lookup è rispondibile in NL.

% ═══ GIRO 1 — Ereditarietà lungo la tassonomia (operatori ordine-2) ═══════════════
% -- fatti base (un passo) PRIMA delle regole --
kind_of(dog, mammal).      kind_of(cat, mammal).     kind_of(human, mammal).
kind_of(whale, mammal).    kind_of(mammal, animal).  kind_of(sparrow, bird).
kind_of(eagle, bird).      kind_of(bird, animal).    kind_of(salmon, fish).
kind_of(fish, animal).     kind_of(animal, living_thing).
kind_of(oak, tree).        kind_of(tree, plant).     kind_of(plant, living_thing).

has_own_prop(living_thing, breathes).   has_own_prop(living_thing, grows).
has_own_prop(living_thing, needs_water). has_own_prop(animal, moves).
has_own_prop(animal, eats).             has_own_prop(mammal, warm_blooded).
has_own_prop(mammal, has_hair).         has_own_prop(bird, has_feathers).
has_own_prop(fish, has_scales).         has_own_prop(plant, photosynthesizes).

has_own_ability(bird, fly).  has_own_ability(fish, swim).
has_own_ability(animal, move). has_own_ability(whale, swim).

% -- operatori: closure transitiva della tassonomia + ereditarietà (right-recursive) --
kind_of_t($X, $Y) :- kind_of($X, $Y).
kind_of_t($X, $Z) :- kind_of($X, $Y), kind_of_t($Y, $Z).
prop_of($X, $P) :- has_own_prop($X, $P).
prop_of($X, $P) :- kind_of($X, $Y), prop_of($Y, $P).
able_to($X, $A) :- has_own_ability($X, $A).
able_to($X, $A) :- kind_of($X, $Y), able_to($Y, $A).

% ═══ GIRO 2 — Ordinamenti transitivi (comparativo + temporale) ════════════════════
% -- fatti base (un passo) --
larger_step(elephant, horse).  larger_step(horse, dog).  larger_step(dog, cat).
larger_step(cat, mouse).       larger_step(mouse, ant).
warmer_step(sun, fire).  warmer_step(fire, boiling_water).  warmer_step(boiling_water, room).
warmer_step(room, ice).  warmer_step(ice, liquid_nitrogen).
time_step(ancient_rome, middle_ages).  time_step(middle_ages, renaissance).
time_step(renaissance, industrial_revolution).
time_step(industrial_revolution, information_age).

% -- operatori: closure right-recursive --
larger_than($X, $Y) :- larger_step($X, $Y).
larger_than($X, $Z) :- larger_step($X, $Y), larger_than($Y, $Z).
warmer_than($X, $Y) :- warmer_step($X, $Y).
warmer_than($X, $Z) :- warmer_step($X, $Y), warmer_than($Y, $Z).
before_in_time($X, $Y) :- time_step($X, $Y).
before_in_time($X, $Z) :- time_step($X, $Y), before_in_time($Y, $Z).

% ═══ GIRO 3 — Parentela: join + ricorsione (operatori ordine-2 / ricorsivi) ═══════
% -- fatti base --
progenitor(tom, bob).   progenitor(bob, ann).   progenitor(ann, zoe).
progenitor(tom, liz).   progenitor(liz, max).   progenitor(zoe, kim).

% -- operatori (primo goal = fatto progenitor → nessuna left-recursion) --
grandparent($X, $Z) :- progenitor($X, $Y), progenitor($Y, $Z).
forebear($X, $Y) :- progenitor($X, $Y).
forebear($X, $Z) :- progenitor($X, $Y), forebear($Y, $Z).

% ═══ COPERTURA RISPONDIBILE (ordine-1, answer_frame su predicati PIATTI) ══════════
% Rendono la conoscenza raggiungibile in NL (lookup). Solo predicati piatti.
answer_frame("wrote", wrote).      answer_frame("author of", wrote).
wrote(shakespeare, hamlet).   wrote(shakespeare, macbeth).   wrote(orwell, nineteen_eighty_four).
wrote(dante, the_divine_comedy). wrote(homer, the_odyssey).  wrote(tolstoy, war_and_peace).
wrote(cervantes, don_quixote).   wrote(mary_shelley, frankenstein).

answer_frame("continent", continent_of).
continent_of(egypt, africa).      continent_of(brazil, south_america).
continent_of(japan, asia).        continent_of(france, europe).
continent_of(canada, north_america). continent_of(australia, oceania).

% nomi propri per il layer di presentazione (chi si capitalizza — conoscenza)
proper_name(south_america).  proper_name(north_america).  proper_name(mary_shelley).
proper_name(don_quixote).    proper_name(ancient_rome).   proper_name(middle_ages).