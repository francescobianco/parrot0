# migrated from tests/cases/algebra2.chat (gen346, hermetic + isolated)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test algebra2]
# gen113: two-step linear equations. gen107 solved one operation; gen113 handles
# a coefficient on the unknown ("2x + 1 = 7"): solve for the value of the term
# coef*var, then divide by the coefficient. Also the one-step coefficient form
# "5y = 20". Held-out numbers; the inversion is reasoned, shown in the proof.

# Two-step: undo the +1, then undo the *2.
> 2x + 1 = 7
< x = 3.
> how do you know?
< Because 2x + 1 = 7, so 2x = 7 - 1, and x = 3.

# Subtraction variant.
> 3x - 2 = 10
< x = 4.

# Coefficient term on the right side of '='.
> 10 = 2x + 4
< x = 3.

# One-step coefficient (no additive term): "5y = 20" -> y = 4.
> 5y = 20
< y = 4.
> 12 = 4x
< x = 3.

# "x = 5" has no coefficient and nothing to solve -> decline, don't echo.
> x = 5
< I don't understand that yet.
