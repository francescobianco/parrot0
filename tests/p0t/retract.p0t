# migrated from tests/cases/retract.chat (gen346, hermetic + isolated;
# expectations aligned to current behaviour).
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test retract]
# Generation 10: retraction & correction — knowledge can be fixed, not only grown.
> socrates is a man
< Learned: man(socrates).
> is socrates a man?
< Yes.
# "forget that X is a Y" removes the fact (and with it, knowledge of `man`).
> forget that socrates is a man
< Forgotten: man(socrates).
> is socrates a man?
< I don't know about man.
# "X is not a Y" stores explicit negative knowledge and clears positive fact.
> bob is a dog
< Learned: dog(bob).
> bob is not a dog
< Learned: not dog(bob).
> is bob a dog?
< No.
> what do you know about bob?
< progenitor(tom, bob); progenitor(bob, ann); bob is not a dog.
> who is a dog?
< Nobody that I know of.
# A later positive assertion clears the matching negative fact.
> bob is a dog
< Learned: dog(bob).
> is bob a dog?
< Yes.
# Retracting something unknown is graceful.
> forget that plato is a man
< I didn't know that anyway.
# Retraction interacts with rules: remove the supporting fact and the
# derived conclusion goes away too.
> plato is a man
< Learned: man(plato).
> every man is a mortal
< Learned rule: mortal(X) :- man(X).
> is plato a mortal?
< Yes.
> forget that plato is a man
< Forgotten: man(plato).
> is plato a mortal?
< No.
