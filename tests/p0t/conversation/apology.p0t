# migrated from tests/cases/apology.chat (aligned to current behaviour)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test apology]
# gen71: apology markers in mod_social — "sorry", "scusa", "scusate", "scusi",
# "mi dispiace" are recognised as phatic apology acts and answered with
# "No problem.". Mixed turns (apology + content) are declined so content
# modules handle the substance. Bilingual ratchet: EN + IT.
> scusa
< No problem.
> sorry
< No problem.
> scusate
< No problem.
> mi dispiace
< No problem.
> scusa, puoi aiutarmi?
< Non capisco ancora.
> mi dispiace, ho sbagliato
< Non ho afferrato bene. Cosa vorresti sapere?
