# migrated from tests/cases/intent_learn.chat (gen346, hermetic + isolated)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test intent_learn]
# gen211+gen214: the surface forms that mean "ask my name" are KB knowledge
# (intent_phrase/2 in kb/core/intents.p0), matched by kb_intent_match. A new form is
# taught through the ONE generic, KB-driven teach path (try_teach_form + learnable/3,
# gen214) — "learn \"…\" to ask my name" — and the very next turn recalls the name
# through it, no code edit and no per-intent handler. "The engine is fixed; the lexicon
# learns" (PRINCIPLES.md).
> my name is Ada
< Nice to meet you, Ada!
> learn "how do you call me" to ask my name
< Got it - I'll take "how do you call me" as a way to ask my name now.
> how do you call me
< Your name is Ada.

