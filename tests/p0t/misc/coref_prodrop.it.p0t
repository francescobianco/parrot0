# migrated from tests/cases/coref_prodrop.it.chat (aligned to current behaviour)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test coref_prodrop.it]
# gen219 (docs/plans/the-linguistic-glue.md, G2 — IT pro-drop pull): Italian drops
# the subject, so "come si chiama" (reflexive "si chiama" -> canon "is called")
# carries NO pronoun for coref to resolve — the EN possessive path ("what is his
# name") cannot fire. Structurally it is a bare name question with a null subject;
# the antecedent is the salient possession (gen217's last_possession_thing). The
# answer is resolved deterministically over real session state, claimed only when
# a recent possession is on record. This completes the bilingual coref ratchet:
# "il mio cane è Rex" then the subjectless "come si chiama" recovers the name.
> il mio cane è Rex
< Got it: your dog is Rex.
> come si chiama
< Your dog is called Rex.
