# migrated from tests/cases/input.it.chat (gen346, hermetic + isolated)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
