# migrated from tests/cases/fewshot.it.chat (hermetic + isolated, perf-held)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test fewshot.it]
!timeout 0
# gen104 (L10) — the bilingual ratchet (LOOP.md). The SAME few-shot code reads
# Italian exemplars because it keys on the arrow markers and the STRUCTURE of the
# transformation, not on any English surface word. No logic is duplicated: the
# competence lives in the algorithm, so it generalizes across languages by
# construction (PRINCIPLES.md — no phrasebook).

# Italian plural: drop the final "o"/"e", append "i" — induced from the examples,
# applied to a held-out noun. This is the suffix-replacement rule, language-free.
> gatto -> gatti, cane -> cani, topo -> ?
< topi.
# The proof cites the Italian exemplars it actually generalized from.
> come lo sai?
< Because the examples gatto -> gatti and cane -> cani share the rule "drop 1, append 'i'", so topo -> topi.

# Numbers are language-neutral; the same numeric induction fires (delta +5).
> 10 -> 15, 20 -> 25, 100 -> ?
< 105.
