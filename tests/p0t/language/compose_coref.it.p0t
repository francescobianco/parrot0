# migrated from tests/cases/compose_coref.it.chat (aligned to current behaviour)
[mock hermetic]
!set PARROT0_BASE=
!set PARROT0_SESSION=
!set PARROT0_WORLD_FACTS=0
!set PARROT0_LANG=en
!reset

[test compose_coref.it]
# gen163 (E1): the possession->coref composition in Italian (mia/gatto/neve) —
# the bilingual ratchet. The named pet becomes the salient entity through the
# same language-agnostic path, so "è essa un animale?" binds "essa" to neve.
> mi chiamo mia
< Piacere di conoscerti, mia!
> ho un gatto chiamato neve
< Got it: your cat is called neve.
> neve è un animale
< Learned: animal(snow).
> è essa un animale?
< Yes.
