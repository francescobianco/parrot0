# build artifacts
/obj/
/bin/

# agent harness state (subagent worktrees, local settings)
/.claude/

# generated session knowledge (base.p0 is curated & tracked)
/kb/core/session.p0

# gen321: the build stamp is generated into the build dir (obj/version_stamp.h,
# already covered by /obj/). src/version.h is now a stable TRACKED declaration —
# keeping a generated header under src/ is what made every commit rebuild the
# whole brain (forge plan §15 row 7).
# editor / OS noise
*.o
*.out
.DS_Store
*.swp
/.idea/
# local Python benchmark dependencies
/.venv/
/.cache/
__pycache__/

# savemap.tsv is a derived index/cache — the (pred,arg1)->file:line routing map
# is regenerated from the kb/ tree on every save (kb_save_routed). Not source.
/kb/savemap.tsv

# env
.env

# gen200: parrot0-written candidate patch copies
*.p0fix

# gen261: parrot0-emitted vocabulary fact files (the emit_facts plan primitive)
*.cues.p0

